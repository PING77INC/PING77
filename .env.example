# LLM API Keys (all three required for multi-model cross-validation)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Database
DATABASE_URL=postgresql://ping77:ping77@localhost:5432/ping77

# Redis
REDIS_URL=redis://localhost:6379

# Market layer (set to "disabled" to run extraction-only mode)
MARKET_LAYER=disabled

# Blockchain (optional, only if MARKET_LAYER=enabled)
RPC_URL=https://mainnet.base.org
FACTORY_ADDRESS=
DEPLOYER_PRIVATE_KEY=0x...

# App
UPLOADS_ENABLED=true
API_PORT=8000
WEB_PORT=3000
